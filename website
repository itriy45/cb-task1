        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Sticky Bottom CTA for Mobile */
        .mobile-cta {
            transform: translateY(100%);
            transition: transform 0.3s ease-in-out;
        }
        .mobile-cta.visible {
            transform: translateY(0);
        }
