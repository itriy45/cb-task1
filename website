    <script>
        // --- Intersection Observer for Scroll Animations ---
        document.addEventListener("DOMContentLoaded", () => {
            const reveals = document.querySelectorAll(".reveal");

            const revealObserver = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("active");
                        // Optional: stop observing once revealed
                        // observer.unobserve(entry.target); 
                    }
                });
            }, {
                root: null,
                rootMargin: "0px",
                threshold: 0.15
            });

            reveals.forEach(reveal => {
                revealObserver.observe(reveal);
            });

            // Mobile Sticky CTA Logic
            const mobileCta = document.getElementById('mobile-cta');
            const heroSection = document.querySelector('section.relative'); // Hero
            
            window.addEventListener('scroll', () => {
                if(window.scrollY > heroSection.offsetHeight) {
                    mobileCta.classList.add('visible');
                } else {
                    mobileCta.classList.remove('visible');
                }
            });
        });

        // --- Tabs Logic for Video Section ---
        function switchTab(tabId, buttonElement) {
            // Remove active classes from all buttons and contents in this container
            const container = buttonElement.closest('.bg-white'); // The wrapper
            const buttons = container.querySelectorAll('.tab-btn');
            const contents = container.querySelectorAll('.tab-content');

            buttons.forEach(btn => btn.classList.remove('active'));
            contents.forEach(content => content.classList.remove('active'));

            // Add active class to clicked button and target content
            buttonElement.classList.add('active');
            document.getElementById(tabId).classList.add('active');
        }

        // --- Accordion Logic ---
        function toggleAccordion(button) {
            const expanded = button.getAttribute('aria-expanded') === 'true';
            const content = button.nextElementSibling;
            
            // Close all other accordions in the same group (optional, but good UX)
            const parentGroup = button.closest('.space-y-3') || button.closest('.bg-white');
            const allButtons = parentGroup.querySelectorAll('.accordion-button');
            
            allButtons.forEach(btn => {
                if (btn !== button && btn.getAttribute('aria-expanded') === 'true') {
                    btn.setAttribute('aria-expanded', 'false');
                    const otherContent = btn.nextElementSibling;
                    otherContent.style.maxHeight = null;
                    otherContent.style.paddingTop = '0px';
                    otherContent.classList.remove('expanded');
                }
            });

            // Toggle current
            if (!expanded) {
                button.setAttribute('aria-expanded', 'true');
                content.classList.add('expanded');
                content.style.paddingTop = '0.5rem';
                content.style.maxHeight = content.scrollHeight + 20 + "px"; // +20 for padding buffer
            } else {
                button.setAttribute('aria-expanded', 'false');
                content.classList.remove('expanded');
                content.style.maxHeight = null;
                setTimeout(() => {
                     content.style.paddingTop = '0px';
                }, 100); // small delay to match transition
            }
        }
    </script>
